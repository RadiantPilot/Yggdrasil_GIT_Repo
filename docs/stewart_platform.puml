@startuml StewartPlatformControlSystem

title Stewart Platform Control System - Class Diagram
footer Object-Oriented Python Design | Raspberry Pi 4B

skinparam classAttributeIconSize 0
skinparam classFontSize 12
skinparam packageFontSize 14
skinparam packageStyle rectangle
skinparam linetype ortho
skinparam nodesep 60
skinparam ranksep 50

' ============================================================
' Package: config
' All tunable parameters gathered here for easy adjustment.
' Serializable to/from YAML for configuration without code changes.
' ============================================================
package "config" #E8F5E9 {

    class PlatformConfig <<dataclass>> {
        + i2c_bus_number : int = 1
        + pca9685_address : int = 0x40
        + pca9685_frequency : int = 50
        + lsm6dsox_address : int = 0x6A
        + base_radius : float
        + platform_radius : float
        + base_joint_angles : list[float]
        + platform_joint_angles : list[float]
        + servo_horn_length : float
        + rod_length : float
        + home_height : float
        + servo_configs : list[ServoConfig]
        + pid_gains : PIDGains
        + control_loop_rate_hz : float
        + safety_config : SafetyConfig
        --
        + {static} load(filepath: str) : PlatformConfig
        + save(filepath: str) : None
        + validate() : None
    }

    class ServoConfig <<dataclass>> {
        + channel : int
        + min_pulse_us : int = 500
        + max_pulse_us : int = 2500
        + min_angle_deg : float = 0.0
        + max_angle_deg : float = 180.0
        + home_angle_deg : float = 90.0
        + direction : int = 1
        + offset_deg : float = 0.0
        + mounting_angle_deg : float = 0.0
    }

    class PIDGains <<dataclass>> {
        + kp : float = 1.0
        + ki : float = 0.0
        + kd : float = 0.0
        + output_min : float = -1.0
        + output_max : float = 1.0
        + integral_limit : float = 100.0
    }

    class SafetyConfig <<dataclass>> {
        + max_translation_mm : float = 50.0
        + max_rotation_deg : float = 30.0
        + max_velocity_mm_per_s : float = 100.0
        + max_angular_velocity_deg_per_s : float = 60.0
        + servo_angle_margin_deg : float = 5.0
        + watchdog_timeout_s : float = 1.0
        + imu_fault_threshold_g : float = 4.0
    }

    PlatformConfig "1" *-- "6" ServoConfig : servo_configs
    PlatformConfig "1" *-- "1" PIDGains : pid_gains
    PlatformConfig "1" *-- "1" SafetyConfig : safety_config
}

' ============================================================
' Package: hardware
' Hardware abstraction layer for I2C bus, PWM driver, and IMUs.
' I2C addresses are configurable for all devices.
' ============================================================
package "hardware" #E3F2FD {

    class I2CBus {
        - _bus_number : int
        - _bus : smbus2.SMBus
        --
        + __init__(bus_number: int)
        + read_byte_data(address: int, register: int) : int
        + write_byte_data(address: int, register: int, value: int) : None
        + read_block_data(address: int, register: int, length: int) : list[int]
        + write_block_data(address: int, register: int, data: list[int]) : None
        + close() : None
        + __enter__() : I2CBus
        + __exit__(...) : None
    }

    class PCA9685Driver {
        - _bus : I2CBus
        - _address : int
        - _frequency : int
        --
        + __init__(bus: I2CBus, address: int, frequency: int)
        + reset() : None
        + set_frequency(freq_hz: int) : None
        + set_pwm(channel: int, on_tick: int, off_tick: int) : None
        + set_pulse_width_us(channel: int, pulse_us: int) : None
        + set_all_pwm(on_tick: int, off_tick: int) : None
        + sleep() : None
        + wake() : None
    }

    interface IMUInterface <<abstract>> {
        + {abstract} configure(**kwargs) : None
        + {abstract} read_acceleration() : Vector3
        + {abstract} read_gyroscope() : Vector3
        + {abstract} read_temperature() : float
        + {abstract} who_am_i() : int
        + {abstract} reset() : None
    }

    class LSM6DSOXDriver {
        - _bus : I2CBus
        - _address : int
        - _accel_range : AccelRange
        - _gyro_range : GyroRange
        - _data_rate : DataRate
        --
        + __init__(bus: I2CBus, address: int)
        + configure(accel_range: AccelRange, gyro_range: GyroRange, data_rate: DataRate) : None
        + read_acceleration() : Vector3
        + read_gyroscope() : Vector3
        + read_temperature() : float
        + who_am_i() : int
        + reset() : None
    }

    enum AccelRange {
        G2
        G4
        G8
        G16
    }

    enum GyroRange {
        DPS125
        DPS250
        DPS500
        DPS1000
        DPS2000
    }

    enum DataRate {
        ODR_12_5_HZ
        ODR_26_HZ
        ODR_52_HZ
        ODR_104_HZ
        ODR_208_HZ
        ODR_416_HZ
        ODR_833_HZ
    }

    IMUInterface <|.. LSM6DSOXDriver : implements
    I2CBus "1" <-- "1" PCA9685Driver : uses
    I2CBus "1" <-- "1" LSM6DSOXDriver : uses
    LSM6DSOXDriver --> AccelRange : uses
    LSM6DSOXDriver --> GyroRange : uses
    LSM6DSOXDriver --> DataRate : uses
}

' ============================================================
' Package: geometry
' Mathematical models for 3D vectors, 6-DOF poses,
' and Stewart platform joint geometry.
' ============================================================
package "geometry" #FFF3E0 {

    class Vector3 {
        + x : float
        + y : float
        + z : float
        --
        + __add__(other: Vector3) : Vector3
        + __sub__(other: Vector3) : Vector3
        + __mul__(scalar: float) : Vector3
        + __neg__() : Vector3
        + magnitude() : float
        + normalized() : Vector3
        + dot(other: Vector3) : float
        + cross(other: Vector3) : Vector3
        + to_array() : np.ndarray
        + {static} from_array(arr: np.ndarray) : Vector3
    }

    class Pose {
        + translation : Vector3
        + rotation : Vector3
        --
        + to_matrix() : np.ndarray
        + {static} from_matrix(m: np.ndarray) : Pose
        + interpolate(other: Pose, t: float) : Pose
        + is_within_bounds(max_translation: float, max_rotation: float) : bool
        + {static} home() : Pose
    }

    class PlatformGeometry {
        - _base_radius : float
        - _platform_radius : float
        - _base_joint_angles : list[float]
        - _platform_joint_angles : list[float]
        - _servo_horn_length : float
        - _rod_length : float
        - _home_height : float
        - _base_joints : list[Vector3]
        - _platform_joints_local : list[Vector3]
        --
        + __init__(config: PlatformConfig)
        - {static} _compute_circle_joints(radius: float, angles_deg: list[float]) : list[Vector3]
        + get_base_joints() : list[Vector3]
        + get_platform_joints_local() : list[Vector3]
        + get_platform_joints_world(pose: Pose) : list[Vector3]
        + get_leg_vectors(pose: Pose) : list[Vector3]
        + get_leg_lengths(pose: Pose) : list[float]
        + compute_home_height() : float
    }

    Pose --> Vector3 : translation, rotation
    PlatformGeometry --> Vector3 : joint positions
    PlatformGeometry --> Pose : computes for
}

' ============================================================
' Package: servo
' Individual servo control with configurable parameters:
' position, angle, rotation direction, and movement range.
' ============================================================
package "servo" #F3E5F5 {

    class Servo {
        - _config : ServoConfig
        - _driver : PCA9685Driver
        - _current_angle_deg : float
        --
        + __init__(config: ServoConfig, driver: PCA9685Driver)
        + set_angle(angle_deg: float) : None
        + get_angle() : float
        + angle_to_pulse_us(angle_deg: float) : int
        + is_within_limits(angle_deg: float) : bool
        + go_home() : None
        + detach() : None
    }

    class ServoArray {
        - _servos : list[Servo]
        - _driver : PCA9685Driver
        --
        + __init__(configs: list[ServoConfig], driver: PCA9685Driver)
        + set_angles(angles: list[float]) : None
        + get_angles() : list[float]
        + go_home() : None
        + detach_all() : None
        + validate_angles(angles: list[float]) : bool
        + __getitem__(index: int) : Servo
    }

    ServoArray "1" *-- "6" Servo : contains
}

' ============================================================
' Package: kinematics
' Inverse kinematics solver for the Stewart platform.
' Converts desired 6-DOF pose to 6 servo angles.
' ============================================================
package "kinematics" #FFFDE7 {

    class InverseKinematics {
        - _geometry : PlatformGeometry
        - _servo_configs : list[ServoConfig]
        --
        + __init__(geometry: PlatformGeometry, servo_configs: list[ServoConfig])
        + solve(pose: Pose) : list[float]
        - _compute_leg_lengths(pose: Pose) : list[float]
        - _leg_length_to_servo_angle(leg_vector: Vector3, servo_index: int) : float
        + is_pose_reachable(pose: Pose) : bool
        + get_workspace_bounds() : tuple[Pose, Pose]
    }
}

' ============================================================
' Package: control
' Motion control: PID controllers, IMU sensor fusion,
' and the main control loop orchestrator.
' ============================================================
package "control" #E0F7FA {

    class PIDController {
        - _gains : PIDGains
        - _integral : float
        - _previous_error : float
        - _previous_time : float
        --
        + __init__(gains: PIDGains)
        + update(setpoint: float, measurement: float, dt: float) : float
        + reset() : None
        + set_gains(gains: PIDGains) : None
    }

    class PoseController {
        - _controllers : list[PIDController]
        --
        + __init__(gains: PIDGains)
        + update(target: Pose, current: Pose, dt: float) : Pose
        + reset() : None
        + set_gains(gains: PIDGains) : None
    }

    class IMUFusion {
        - _alpha : float
        - _current_orientation : Vector3
        - _last_time : float
        --
        + __init__(alpha: float = 0.98)
        + update(accel: Vector3, gyro: Vector3, dt: float) : Vector3
        + get_orientation() : Vector3
        + reset() : None
    }

    class MotionController {
        - _config : PlatformConfig
        - _servo_array : ServoArray
        - _base_imu : IMUInterface
        - _ik_solver : InverseKinematics
        - _pose_controller : PoseController
        - _imu_fusion : IMUFusion
        - _safety_monitor : SafetyMonitor
        - _target_pose : Pose
        - _current_pose : Pose
        - _running : bool
        - _loop_rate_hz : float
        --
        + __init__(config: PlatformConfig)
        + initialize() : None
        + set_target_pose(pose: Pose) : None
        + start() : None
        + stop() : None
        + emergency_stop() : None
        + step() : None
        + get_current_pose() : Pose
        + get_servo_angles() : list[float]
        + is_running() : bool
        + shutdown() : None
        + «property» target_pose : Pose
        + «property» pose_controller : PoseController
        + «property» safety_monitor : SafetyMonitor
        + «property» imu_fusion : IMUFusion
        + «property» base_imu : IMUInterface
        + «property» servo_array : ServoArray
    }

    PoseController "1" *-- "6" PIDController : one per DOF
    IMUFusion --> Vector3 : orientation
}

' ============================================================
' Package: safety
' Safety validation layer: limit checking, velocity bounds,
' emergency stop, and watchdog.
' ============================================================
package "safety" #FFEBEE {

    class SafetyMonitor {
        - _config : SafetyConfig
        - _servo_configs : list[ServoConfig]
        - _last_pose : Pose
        - _last_time : float
        - _emergency_stopped : bool
        --
        + __init__(config: SafetyConfig, servo_configs: list[ServoConfig])
        + validate_pose(pose: Pose) : bool
        + validate_servo_angles(angles: list[float]) : bool
        + validate_velocity(current: Pose, previous: Pose, dt: float) : bool
        + validate_imu_readings(accel: Vector3) : bool
        + trigger_emergency_stop() : None
        + reset_emergency_stop() : None
        + is_emergency_stopped() : bool
        + check_all(pose: Pose, angles: list[float], accel: Vector3, dt: float) : SafetyCheckResult
    }

    class SafetyCheckResult <<dataclass>> {
        + is_safe : bool
        + violations : list[str]
        + severity : SafetySeverity
    }

    enum SafetySeverity {
        WARNING
        ERROR
        CRITICAL
    }

    SafetyMonitor --> SafetyCheckResult : produces
    SafetyCheckResult --> SafetySeverity : severity
}

' ============================================================
' Cross-package relationships
' ============================================================

' Servo dependencies
Servo --> ServoConfig : configured by
Servo --> PCA9685Driver : commands via
ServoArray --> PCA9685Driver : uses

' Kinematics dependencies
InverseKinematics --> PlatformGeometry : uses
InverseKinematics --> ServoConfig : reads limits
InverseKinematics --> Pose : solves for
InverseKinematics --> Vector3 : leg vectors

' Geometry dependencies
PlatformGeometry --> PlatformConfig : reads from

' Control dependencies
PIDController --> PIDGains : configured by
MotionController --> PlatformConfig : configured by
MotionController --> ServoArray : commands
MotionController --> IMUInterface : reads sensors
MotionController --> InverseKinematics : solves IK
MotionController --> PoseController : feedback control
MotionController --> IMUFusion : orientation fusion
MotionController --> SafetyMonitor : safety validation
MotionController --> Pose : target / current

' Safety dependencies
SafetyMonitor --> SafetyConfig : configured by
SafetyMonitor --> ServoConfig : checks limits
SafetyMonitor --> Pose : validates
SafetyMonitor --> Vector3 : checks IMU

@enduml
