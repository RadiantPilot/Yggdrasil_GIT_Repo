    }

    class PoseSliders <<QWidget>> {
        - _sliders : dict[str, QSlider]
        - _spins : dict[str, QDoubleSpinBox]
        .. Qt-signaler ..
        + pose_changed : Signal(dict)
        --
        + get_values() : dict[str, float]
