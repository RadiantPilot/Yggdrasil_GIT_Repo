        + append_values(values: list[float]) : None
        + refresh() : None
        + clear_data() : None
        + set_series_visible(index: int, visible: bool) : None
        + set_window_size(size: int) : None
        + series_names : list[str]
        - _apply_theme(theme: Theme) : None
    }

    class ResponsePlot <<pg.PlotWidget>> {
        - _setpoint_curve : pg.PlotDataItem
        - _actual_curve : pg.PlotDataItem
        - _metrics_text : pg.TextItem
        --
        + set_data(t, setpoint, actual) : None
        + clear_data() : None
        - _update_metrics(...) : None
        - _apply_theme(theme: Theme) : None
    }

    IndicatorLamp *-- _LedDot
    EventLog "1" *-- "*" Event
}

' ════════════════════════════════════════════════════════════
' LAG 8 — GUI: UTILS (hjelpe-klasser)
' ════════════════════════════════════════════════════════════
package "gui.utils" #F9FBE7 {

    class Theme <<dataclass, frozen>> {
        + name : str
        + window_bg / window_fg : str
        + base_bg / alternate_bg : str
        + tooltip_bg / tooltip_fg : str
        + button_bg / button_fg : str
        + highlight / highlight_fg : str
        + border / muted_fg : str
        + plot_bg / plot_fg / plot_axis : str
        + grid_alpha : float
    }

    class ThemeManager <<QObject, singleton>> {
        - {static} _instance : ThemeManager | None
        - _current : Theme
        .. Qt-signaler ..
        + theme_changed : Signal(Theme)
        --
        + {static} instance() : ThemeManager
        + current : Theme
        + apply(theme: Theme) : None
        + toggle() : Theme
    }

    class RingBuffer {
        - _capacity : int
        - _data : np.ndarray
        - _index : int
        - _count : int
        --
        + __init__(capacity: int, channels: int = 1)
        + capacity : int
        + count : int
        + append(values) : None
        + get_data() : np.ndarray
        + get_channel(ch: int) : np.ndarray
        + clear() : None
    }

    class "<<module>>\nformatting" as formatting {
        + fmt_mm(v, decimals=2) : str
        + fmt_deg(v, decimals=2) : str
        + fmt_accel(v) : str
        + fmt_gyro(v) : str
        + fmt_hz(v) : str
        + fmt_time(seconds) : str
    }

    ThemeManager --> Theme
}

' ════════════════════════════════════════════════════════════
' LAG 9 — GUI: APP (rot, vindu, innstegspunkt)
' ════════════════════════════════════════════════════════════
package "gui" #F3E5F5 {

    class MainWindow <<QMainWindow>> {
        - _bridge : ControllerBridge
        - _tabs : QTabWidget
        - _tab_overview : OverviewTab
        - _tab_pose : PoseControlTab
        - _tab_pid : PidTuningTab
        - _tab_imu : ImuTab
        - _tab_config : ConfigTab
        - _tab_safety : SafetyTab
        - _btn_start / _btn_stop / _btn_home : QPushButton
        - _btn_estop / _btn_theme : QPushButton
        - _lbl_mode / _lbl_rate : QLabel
        --
        + __init__(bridge: ControllerBridge)
        + on_snapshot(snapshot: StateSnapshot) : None
        - _on_start_clicked() / _on_stop_clicked() : None
        - _on_home_clicked() / _on_estop_clicked() : None
        - _on_theme_toggle() : None
        - _on_tab_changed(index: int) : None
    }

    class "<<module>>\napp" as app_module {
        + main() : int
        - _parse_args() : argparse.Namespace
    }

    MainWindow "1" *-- "6" BaseTab : via QTabWidget
    app_module ..> MainWindow : oppretter
    app_module ..> ControllerBridge : oppretter
    app_module ..> PollingWorker : oppretter
    app_module ..> ThemeManager : bruker
}

